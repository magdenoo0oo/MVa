@model StudentManagement.Models.Student
@{
    ViewData["Title"] = "Student Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-user"></i> Student Details
    </h2>
    <div>
        @if (User.IsInRole("Admin") || User.IsInRole("Student"))
        {
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
        }
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                @if (!string.IsNullOrEmpty(Model?.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="@Model.FullName" class="rounded-circle mb-3" 
                         style="width: 200px; height: 200px; object-fit: cover;" />
                }
                else
                {
                    <div class="bg-secondary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" 
                         style="width: 200px; height: 200px;">
                        <i class="fas fa-user fa-5x text-white"></i>
                    </div>
                }
                
                <h4>@Model?.FullName</h4>
                <p class="text-muted">@Model?.Email</p>
                
                @if (Model?.GPA.HasValue == true)
                {
                    var gpaClass = Model.GPA.Value >= 3.5 ? "bg-success" : Model.GPA.Value >= 2.5 ? "bg-warning" : "bg-danger";
                    <span class="badge @gpaClass fs-6">GPA: @Model.GPA.Value.ToString("F2")</span>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-info-circle"></i> Personal Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-5">First Name:</dt>
                            <dd class="col-sm-7">@Model?.FirstName</dd>
                            
                            <dt class="col-sm-5">Last Name:</dt>
                            <dd class="col-sm-7">@Model?.LastName</dd>
                            
                            <dt class="col-sm-5">Email:</dt>
                            <dd class="col-sm-7">
                                <a href="mailto:@Model?.Email">@Model?.Email</a>
                            </dd>
                            
                            <dt class="col-sm-5">Phone:</dt>
                            <dd class="col-sm-7">
                                <a href="tel:@Model?.PhoneNumber">@Model?.PhoneNumber</a>
                            </dd>
                        </dl>
                    </div>
                    
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-5">Date of Birth:</dt>
                            <dd class="col-sm-7">@Model?.DateOfBirth.ToString("MMMM dd, yyyy")</dd>
                            
                            <dt class="col-sm-5">Age:</dt>
                            <dd class="col-sm-7">
                                @if (Model?.DateOfBirth != null)
                                {
                                    var age = DateTime.Today.Year - Model.DateOfBirth.Year;
                                    if (Model.DateOfBirth.Date > DateTime.Today.AddYears(-age)) age--;
                                    @age <text>years old</text>
                                }
                            </dd>
                            
                            <dt class="col-sm-5">Department:</dt>
                            <dd class="col-sm-7">
                                <span class="badge bg-primary fs-6">@Model?.Department?.Name</span>
                            </dd>
                            
                            <dt class="col-sm-5">Enrollment Date:</dt>
                            <dd class="col-sm-7">@Model?.EnrollmentDate.ToString("MMMM dd, yyyy")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
        
        @if (Model?.Department != null)
        {
            <div class="card mt-3">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-building"></i> Department Information
                    </h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Department:</dt>
                        <dd class="col-sm-9">@Model.Department.Name</dd>
                        
                        @if (!string.IsNullOrEmpty(Model.Department.Description))
                        {
                            <dt class="col-sm-3">Description:</dt>
                            <dd class="col-sm-9">@Model.Department.Description</dd>
                        }
                        
                        <dt class="col-sm-3">Budget:</dt>
                        <dd class="col-sm-9">$@Model.Department.Budget.ToString("N0")</dd>
                        
                        @if (Model.Department.EstablishedDate.HasValue)
                        {
                            <dt class="col-sm-3">Established:</dt>
                            <dd class="col-sm-9">@Model.Department.EstablishedDate.Value.ToString("MMMM dd, yyyy")</dd>
                        }
                    </dl>
                    
                    <a asp-controller="Departments" asp-action="Details" asp-route-id="@Model.Department.Id" 
                       class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-eye"></i> View Department Details
                    </a>
                </div>
            </div>
        }
    </div>
</div>