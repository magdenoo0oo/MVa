@model IEnumerable<StudentManagement.Models.Student>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Photo</th>
                <th>Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>GPA</th>
                <th>Enrollment Date</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" alt="@item.FullName" class="rounded-circle" width="40" height="40" style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <span aria-hidden="true" class="text-white">👤</span>
                            </div>
                        }
                    </td>
                    <td>
                        <strong>@item.FullName</strong><br>
                        <small class="text-muted">@item.PhoneNumber</small>
                    </td>
                    <td>@item.Email</td>
                    <td>
                        <span class="badge bg-primary">@item.Department?.Name</span>
                    </td>
                    <td>
                        @if (item.GPA.HasValue)
                        {
                            var gpaClass = item.GPA.Value >= 3.5 ? "bg-success" : item.GPA.Value >= 2.5 ? "bg-warning" : "bg-danger";
                            <span class="badge @gpaClass">@item.GPA.Value.ToString("F2")</span>
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </td>
                    <td>@item.EnrollmentDate.ToString("MMM dd, yyyy")</td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="View Details">
                                <span aria-hidden="true">👁️</span>
                            </a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Student"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Edit">
                                    ✏️
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                    🗑️
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    @if (!Model.Any())
    {
        <div class="text-center py-4">
            <span class="fa-3x text-muted mb-3" aria-hidden="true">🔎</span>
            <h5 class="text-muted">No students found</h5>
            <p class="text-muted">Try adjusting your search criteria</p>
        </div>
    }
</div>