@model StudentManagement.Models.Student
@{
    ViewData["Title"] = "Delete Student";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 border-danger">
                <div class="card-header bg-gradient-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-user-times me-2"></i>Delete Student
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this student record?
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4 text-center">
                            @if (!string.IsNullOrEmpty(Model.ImagePath))
                            {
                                <img src="@Model.ImagePath" alt="@Model.FullName" class="img-thumbnail rounded-circle mb-3" 
                                     style="width: 150px; height: 150px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-secondary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" 
                                     style="width: 150px; height: 150px;">
                                    <i class="fas fa-user fa-4x text-white"></i>
                                </div>
                            }
                            <h5>@Model.FullName</h5>
                            @if (Model.GPA.HasValue)
                            {
                                var gpaClass = Model.GPA.Value >= 3.5 ? "bg-success" : Model.GPA.Value >= 2.5 ? "bg-warning" : "bg-danger";
                                <span class="badge @gpaClass fs-6">GPA: @Model.GPA.Value.ToString("F2")</span>
                            }
                        </div>
                        
                        <div class="col-md-8">
                            <div class="row">
                                <div class="col-md-6">
                                    <dl class="row">
                                        <dt class="col-sm-5">ID:</dt>
                                        <dd class="col-sm-7">@Model.Id</dd>
                                        
                                        <dt class="col-sm-5">Email:</dt>
                                        <dd class="col-sm-7">@Model.Email</dd>
                                        
                                        <dt class="col-sm-5">Phone:</dt>
                                        <dd class="col-sm-7">@Model.PhoneNumber</dd>
                                        
                                        <dt class="col-sm-5">Department:</dt>
                                        <dd class="col-sm-7">
                                            <span class="badge bg-primary">@Model.Department?.Name</span>
                                        </dd>
                                    </dl>
                                </div>
                                <div class="col-md-6">
                                    <dl class="row">
                                        <dt class="col-sm-5">Birth Date:</dt>
                                        <dd class="col-sm-7">@Model.DateOfBirth.ToString("MMM dd, yyyy")</dd>
                                        
                                        <dt class="col-sm-5">Age:</dt>
                                        <dd class="col-sm-7">
                                            @{
                                                var age = DateTime.Today.Year - Model.DateOfBirth.Year;
                                                if (Model.DateOfBirth.Date > DateTime.Today.AddYears(-age)) age--;
                                            }
                                            @age years old
                                        </dd>
                                        
                                        <dt class="col-sm-5">Enrolled:</dt>
                                        <dd class="col-sm-7">@Model.EnrollmentDate.ToString("MMM dd, yyyy")</dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="fas fa-trash-alt me-2"></i>Delete Student
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>