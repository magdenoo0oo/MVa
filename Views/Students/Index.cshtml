@model PaginatedList<StudentManagement.Models.Student>
@{
    ViewData["Title"] = "Students";
}

<div class="flex items-center justify-between mb-4">
    <h2>👥 Students</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Student"))
    {
        <a asp-action="Create" class="btn btn-primary">➕ Add New Student</a>
    }
</div>

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col-6">
                <form asp-action="Index" method="get">
                    <div class="flex gap-2">
                        <input type="text" name="search" value="@ViewData["CurrentFilter"]" 
                               class="" placeholder="Search students..." id="searchInput" />
                        <button class="btn btn-outline" type="submit">Search</button>
                    </div>
                </form>
            </div>
            <div class="col-6">
                <div class="flex justify-end gap-2">
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" 
                       asp-route-search="@ViewData["CurrentFilter"]" class="btn btn-outline">
                        Name
                    </a>
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["IdSortParm"]" 
                       asp-route-search="@ViewData["CurrentFilter"]" class="btn btn-outline">
                        ID
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div id="studentsContainer">
            @await Html.PartialAsync("_StudentsList", Model)
        </div>
    </div>
</div>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<nav aria-label="Students pagination" class="mt-3">
    <ul class="pagination justify-center">
        <li class="page-item @prevDisabled">
            <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
               asp-route-page="@(Model.PageIndex - 1)" asp-route-search="@ViewData["CurrentFilter"]">
                ◀️ Previous
            </a>
        </li>
        
        @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
                   asp-route-page="@i" asp-route-search="@ViewData["CurrentFilter"]">@i</a>
            </li>
        }
        
        <li class="page-item @nextDisabled">
            <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
               asp-route-page="@(Model.PageIndex + 1)" asp-route-search="@ViewData["CurrentFilter"]">
                Next ▶️
            </a>
        </li>
    </ul>
</nav>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form[asp-action="Index"], form[action*="/Students/Index"]');
            if (form) {
                form.dataset.searchUrl = '@Url.Action("Search", "Students")';
            }
        });
    </script>
}