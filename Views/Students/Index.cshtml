@model PaginatedList<StudentManagement.Models.Student>
@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-users"></i> Students
    </h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Student"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New Student
        </a>
    }
</div>

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col-md-6">
                <form asp-action="Index" method="get">
                    <div class="input-group">
                        <input type="text" name="search" value="@ViewData["CurrentFilter"]" 
                               class="form-control" placeholder="Search students..." id="searchInput" />
                        <button class="btn btn-outline-secondary" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>
            <div class="col-md-6">
                <div class="btn-group float-end" role="group">
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" 
                       asp-route-search="@ViewData["CurrentFilter"]" class="btn btn-outline-secondary">
                        <i class="fas fa-sort-alpha-down"></i> Name
                    </a>
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["IdSortParm"]" 
                       asp-route-search="@ViewData["CurrentFilter"]" class="btn btn-outline-secondary">
                        <i class="fas fa-sort-numeric-down"></i> ID
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div id="studentsContainer">
            @await Html.PartialAsync("_StudentsList", Model)
        </div>
    </div>
</div>

<!-- Pagination -->
@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<nav aria-label="Students pagination" class="mt-3">
    <ul class="pagination justify-content-center">
        <li class="page-item @prevDisabled">
            <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
               asp-route-page="@(Model.PageIndex - 1)" asp-route-search="@ViewData["CurrentFilter"]">
                <i class="fas fa-chevron-left"></i> Previous
            </a>
        </li>
        
        @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
                   asp-route-page="@i" asp-route-search="@ViewData["CurrentFilter"]">@i</a>
            </li>
        }
        
        <li class="page-item @nextDisabled">
            <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
               asp-route-page="@(Model.PageIndex + 1)" asp-route-search="@ViewData["CurrentFilter"]">
                Next <i class="fas fa-chevron-right"></i>
            </a>
        </li>
    </ul>
</nav>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#searchInput').on('keyup', function() {
                var searchString = $(this).val();
                
                $.ajax({
                    url: '@Url.Action("Search", "Students")',
                    type: 'POST',
                    data: { searchString: searchString },
                    success: function(data) {
                        $('#studentsContainer').html(data);
                    }
                });
            });
        });
    </script>
}