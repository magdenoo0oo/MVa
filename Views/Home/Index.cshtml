@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-section bg-primary text-white py-5 mb-4 rounded">
    <div class="container text-center">
        <h1 class="display-4">
            <i class="fas fa-graduation-cap"></i> 
            Student Management System
        </h1>
        <p class="lead">Efficiently manage departments and students with our comprehensive system</p>
        @if (!User.Identity.IsAuthenticated)
        {
            <div class="mt-4">
                <a class="btn btn-light btn-lg me-3" asp-controller="Account" asp-action="Login">
                    <i class="fas fa-sign-in-alt"></i> Login
                </a>
                <a class="btn btn-outline-light btn-lg" asp-controller="Account" asp-action="Register">
                    <i class="fas fa-user-plus"></i> Register
                </a>
            </div>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="fas fa-building fa-3x text-primary mb-3"></i>
                <h5 class="card-title">Department Management</h5>
                <p class="card-text">View and manage all departments within the organization. Track budgets, establishment dates, and associated students.</p>
                <a href="@Url.Action("Index", "Departments")" class="btn btn-primary">
                    <i class="fas fa-eye"></i> View Departments
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="fas fa-users fa-3x text-success mb-3"></i>
                <h5 class="card-title">Student Management</h5>
                <p class="card-text">Manage student records, track their academic progress, and maintain their personal information and profile images.</p>
                <a href="@Url.Action("Index", "Students")" class="btn btn-success">
                    <i class="fas fa-eye"></i> View Students
                </a>
            </div>
        </div>
    </div>
</div>

@if (User.Identity.IsAuthenticated)
{
    <div class="mt-5">
        <div class="row">
            <div class="col-12">
                <div class="card bg-light">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-info-circle"></i> Quick Actions
                        </h5>
                        <div class="row">
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="col-md-3">
                                    <a class="btn btn-outline-primary btn-sm w-100 mb-2" asp-controller="Departments" asp-action="Create">
                                        <i class="fas fa-plus"></i> Add Department
                                    </a>
                                </div>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("Student"))
                            {
                                <div class="col-md-3">
                                    <a class="btn btn-outline-success btn-sm w-100 mb-2" asp-controller="Students" asp-action="Create">
                                        <i class="fas fa-plus"></i> Add Student
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}