@model StudentManagement.Models.Department
@{
    ViewData["Title"] = "Create Department";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-gradient-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle me-2"></i>Create New Department
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" id="departmentForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Name" class="form-control" placeholder="Department Name" />
                                    <label asp-for="Name" class="form-label">
                                        <i class="fas fa-building me-1"></i>Department Name
                                    </label>
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Budget" class="form-control" placeholder="Budget" />
                                    <label asp-for="Budget" class="form-label">
                                        <i class="fas fa-dollar-sign me-1"></i>Budget ($)
                                    </label>
                                    <span asp-validation-for="Budget" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-floating mb-3">
                            <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 100px"></textarea>
                            <label asp-for="Description" class="form-label">
                                <i class="fas fa-align-left me-1"></i>Description
                            </label>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="EstablishedDate" class="form-control" type="date" />
                            <label asp-for="EstablishedDate" class="form-label">
                                <i class="fas fa-calendar me-1"></i>Established Date
                            </label>
                            <span asp-validation-for="EstablishedDate" class="text-danger"></span>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Create Department
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}