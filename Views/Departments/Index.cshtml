@model PaginatedList<StudentManagement.Models.Department>
@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <span aria-hidden="true">🏢</span> Departments
    </h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <span aria-hidden="true">➕</span> Create New Department
        </a>
    }
</div>

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col-md-6">
                <form asp-action="Index" method="get">
                    <div class="input-group">
                        <input type="text" name="search" value="@ViewData["CurrentFilter"]" 
                               class="form-control search-input" placeholder="Search departments..." id="searchInput" />
                        <button class="btn btn-outline-secondary" type="submit">Search</button>
                    </div>
                </form>
            </div>
            <div class="col-md-6">
                <div class="btn-group float-end" role="group">
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" 
                       asp-route-search="@ViewData["CurrentFilter"]" class="btn btn-outline-secondary">
                        Name
                    </a>
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["IdSortParm"]" 
                       asp-route-search="@ViewData["CurrentFilter"]" class="btn btn-outline-secondary">
                        ID
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div id="departmentsContainer">
            @await Html.PartialAsync("_DepartmentsList", Model)
        </div>
    </div>
</div>

<!-- Pagination -->
@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<nav aria-label="Departments pagination" class="mt-3">
    <ul class="pagination justify-content-center">
        <li class="page-item @prevDisabled">
            <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
               asp-route-page="@(Model.PageIndex - 1)" asp-route-search="@ViewData["CurrentFilter"]">
                ◀️ Previous
            </a>
        </li>
        
        @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
                   asp-route-page="@i" asp-route-search="@ViewData["CurrentFilter"]">@i</a>
            </li>
        }
        
        <li class="page-item @nextDisabled">
            <a class="page-link" asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" 
               asp-route-page="@(Model.PageIndex + 1)" asp-route-search="@ViewData["CurrentFilter"]">
                Next ▶️
            </a>
        </li>
    </ul>
</nav>

@section Scripts {
    <script>
        // Use global site.js debounced search if AJAX is wired via data-search-url
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form[asp-action="Index"], form[action*="/Departments/Index"]');
            if (form) {
                form.dataset.searchUrl = '@Url.Action("Search", "Departments")';
            }
        });
    </script>
}