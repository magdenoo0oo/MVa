@model StudentManagement.Models.Department
@{
    ViewData["Title"] = "Department Details";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-gradient-info text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-building me-2"></i>@Model.Name
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">
                                    <i class="fas fa-hashtag me-1"></i>ID:
                                </dt>
                                <dd class="col-sm-8">@Model.Id</dd>
                                
                                <dt class="col-sm-4">
                                    <i class="fas fa-building me-1"></i>Name:
                                </dt>
                                <dd class="col-sm-8"><strong>@Model.Name</strong></dd>
                                
                                <dt class="col-sm-4">
                                    <i class="fas fa-dollar-sign me-1"></i>Budget:
                                </dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-success fs-6">$@Model.Budget.ToString("N0")</span>
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">
                                    <i class="fas fa-calendar me-1"></i>Established:
                                </dt>
                                <dd class="col-sm-8">
                                    @if (Model.EstablishedDate.HasValue)
                                    {
                                        @Model.EstablishedDate.Value.ToString("MMMM dd, yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not set</span>
                                    }
                                </dd>
                                
                                <dt class="col-sm-4">
                                    <i class="fas fa-users me-1"></i>Students:
                                </dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-primary fs-6">@Model.Students.Count</span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mt-3">
                            <h6><i class="fas fa-align-left me-1"></i>Description:</h6>
                            <p class="text-muted">@Model.Description</p>
                        </div>
                    }
                    
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <div>
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
                                    <i class="fas fa-edit me-2"></i>Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card shadow border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-users me-2"></i>Students in Department
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Students.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var student in Model.Students.Take(5))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@student.FullName</strong><br>
                                        <small class="text-muted">@student.Email</small>
                                    </div>
                                    @if (student.GPA.HasValue)
                                    {
                                        var gpaClass = student.GPA.Value >= 3.5 ? "bg-success" : student.GPA.Value >= 2.5 ? "bg-warning" : "bg-danger";
                                        <span class="badge @gpaClass">@student.GPA.Value.ToString("F2")</span>
                                    }
                                </div>
                            }
                        </div>
                        
                        @if (Model.Students.Count > 5)
                        {
                            <div class="text-center mt-3">
                                <small class="text-muted">And @(Model.Students.Count - 5) more students...</small>
                            </div>
                        }
                        
                        <div class="text-center mt-3">
                            <a asp-controller="Students" asp-action="Index" asp-route-search="@Model.Name" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-eye me-1"></i>View All Students
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted">
                            <i class="fas fa-users fa-3x mb-3"></i>
                            <p>No students in this department yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>