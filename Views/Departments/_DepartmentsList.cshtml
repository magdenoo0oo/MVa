@model IEnumerable<StudentManagement.Models.Department>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
                <th>Budget</th>
                <th>Established Date</th>
                <th>Students Count</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        <strong>@item.Name</strong>
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            @(item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)
                        }
                        else
                        {
                            <span class="text-muted">No description</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-success">$@item.Budget.ToString("N0")</span>
                    </td>
                    <td>
                        @if (item.EstablishedDate.HasValue)
                        {
                            @item.EstablishedDate.Value.ToString("MMM dd, yyyy")
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-info">@item.Students.Count</span>
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="View Details">
                                <span aria-hidden="true">👁️</span>
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Edit">
                                    ✏️
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                    🗑️
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    @if (!Model.Any())
    {
        <div class="text-center py-4">
            <span class="fa-3x text-muted mb-3" aria-hidden="true">🔎</span>
            <h5 class="text-muted">No departments found</h5>
            <p class="text-muted">Try adjusting your search criteria</p>
        </div>
    }
</div>