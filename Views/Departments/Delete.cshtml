@model StudentManagement.Models.Department
@{
    ViewData["Title"] = "Delete Department";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 border-danger">
                <div class="card-header bg-gradient-danger text-white">
                    <h4 class="mb-0">
                        <span class="me-2" aria-hidden="true">🗑️</span>Delete Department
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning" role="alert">
                        <span class="me-2" aria-hidden="true">⚠️</span>
                        <strong>Warning!</strong> Are you sure you want to delete this department?
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Name:</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>
                                
                                <dt class="col-sm-4">Budget:</dt>
                                <dd class="col-sm-8">$@Html.DisplayFor(model => model.Budget)</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Established:</dt>
                                <dd class="col-sm-8">
                                    @if (Model.EstablishedDate.HasValue)
                                    {
                                        @Model.EstablishedDate.Value.ToString("MMMM dd, yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not set</span>
                                    }
                                </dd>
                                
                                <dt class="col-sm-4">Students:</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-info">@Model.Students.Count</span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mt-3">
                            <strong>Description:</strong>
                            <p class="text-muted">@Model.Description</p>
                        </div>
                    }
                    
                    @if (Model.Students.Any())
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            <span class="me-2" aria-hidden="true">⛔</span>
                            <strong>Cannot Delete!</strong> This department has @Model.Students.Count student(s) assigned. 
                            Please reassign students to other departments before deleting.
                        </div>
                    }
                    
                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                ◀️ Back to List
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg" @(Model.Students.Any() ? "disabled" : "")>
                                🗑️ Delete Department
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>