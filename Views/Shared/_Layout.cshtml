<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Student Management</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="navbar">
        <div class="container navbar-inner">
            <a class="brand" asp-controller="Home" asp-action="Index">🎓 Student Management</a>
            <button class="toggle" aria-label="Toggle navigation">☰</button>
            <nav class="nav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Departments" asp-action="Index">Departments</a>
                <a asp-controller="Students" asp-action="Index">Students</a>
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="p-2">👤 @User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                        <button type="submit" class="btn btn-outline btn-sm">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login">Login</a>
                    <a asp-controller="Account" asp-action="Register">Register</a>
                }
            </nav>
        </div>
    </header>

    <main role="main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer>
        <div class="container flex items-center justify-between">
            <div>© @DateTime.UtcNow.Year Student Management</div>
            <div class="text-muted">Built with plain HTML, CSS, and JS</div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
