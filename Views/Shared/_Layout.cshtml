<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Management System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <meta name="theme-color" content="#667eea">
    <meta name="description" content="Modern Student Management System - Manage departments and students efficiently">
</head>
<body>
    <header>
        <nav class="navbar mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span aria-hidden="true">🎓</span> Student Management
                </a>
                <button class="navbar-toggler" type="button" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation" data-toggle-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">
                                <span aria-hidden="true">🏠</span> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Departments" asp-action="Index">
                                <span aria-hidden="true">🏢</span> Departments
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Students" asp-action="Index">
                                <span aria-hidden="true">👥</span> Students
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" role="button" href="javascript:void(0);">
                                    <span aria-hidden="true">⚙️</span> Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Departments" asp-action="Create">
                                            <span aria-hidden="true" class="me-2">➕</span>Add Department
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Students" asp-action="Create">
                                            <span aria-hidden="true" class="me-2">👤➕</span>Add Student
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" role="button" href="javascript:void(0);">
                                    <span aria-hidden="true">👤</span> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <h6 class="dropdown-header">
                                            <span aria-hidden="true" class="me-1">ℹ️</span>
                                            Role: @(User.IsInRole("Admin") ? "Administrator" : "Student")
                                        </h6>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt"></i> Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Account" asp-action="Register">
                                    <i class="fas fa-user-plus"></i> Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <span class="me-2" aria-hidden="true">⛔</span>
                    @TempData["Error"]
                    <button type="button" class="btn-close" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <span class="me-2" aria-hidden="true">✅</span>
                    @TempData["Success"]
                    <button type="button" class="btn-close" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-white">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span>&copy; 2025 Student Management System</span>
                </div>
                <div class="col-md-6 text-end">
                    <a class="text-white-50 me-3" asp-controller="Home" asp-action="Privacy">
                        <span class="me-1" aria-hidden="true">🛡️</span>Privacy
                    </a>
                    <span class="text-white-50">Built with <span aria-hidden="true">❤️</span></span>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
